# Backend environment — copy to backend/.env and fill in real values.
# On the EC2 box this file is read by docker-compose (env_file) and injected into the container.

# --- Supabase (database + auth + storage) — REQUIRED ---
SUPABASE_URL=YOUR_SUPABASE_URL_HERE
SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# --- Zoom (live classes) — required for live-class features ---
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_SDK_KEY=
ZOOM_SDK_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=

# --- Email ---
RESEND_API_KEY=

# --- AI mentor insights ---
# The provider/key/model are configured ENTIRELY here (never in the frontend or DB).
# AI_PROVIDER selects the backend; default is gemini. To switch providers later
# (e.g. to Groq) just change AI_PROVIDER and set its key — no code change.
AI_PROVIDER=gemini
# Gemini (default). Must be a NON-EMPTY value: load_dotenv runs with override=True,
# so an empty GEMINI_API_KEY= here will blank a key injected via the host/Docker env.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Groq (OpenAI-compatible). Set AI_PROVIDER=groq and fill GROQ_API_KEY to use it.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
# OpenAI (OpenAI-compatible). Set AI_PROVIDER=openai and fill OPENAI_API_KEY to use it.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Cloudflare R2 (all file storage + DB backups). Set all of ACCOUNT_ID/ACCESS_KEY/
#     SECRET_KEY/PUBLIC_BUCKET to enable R2; omit them to fall back to Supabase Storage. ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_PUBLIC_BUCKET=udaya-public
R2_PRIVATE_BUCKET=udaya-private
# Public base URL for served files (R2 public bucket custom domain). No trailing slash.
R2_PUBLIC_BASE_URL=https://files.udaya-learn.com
# Storage is fail-closed: if R2 isn't configured, uploads RAISE instead of using
# Supabase Storage. Set to 1 ONLY for local dev if you want the Supabase fallback.
STORAGE_ALLOW_SUPABASE=

# --- Optional: error monitoring + weekly DB backup target ---
SENTRY_DSN=
# Supabase pooler connection string, used only by backend/scripts/backup_db.py
DATABASE_URL=
