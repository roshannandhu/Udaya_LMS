# Baileys WhatsApp microservice — copy to whatsapp-service/.env
# This service is INTERNAL only (docker network). Never expose it publicly.

# Port FastAPI reaches it on (3001 is the Vite dev server — do not reuse it).
PORT=3100

# Shared secret: FastAPI must send this as the X-Service-Token header. Generate a
# long random string and put the SAME value in backend/.env as SHARED_TOKEN.
SHARED_TOKEN=

# Week-1 warm-up cap. The ladder ramps 50 -> 100 -> 200 -> 500 over the first
# weeks since the number first connected. This value sets the week-1 number.
DAILY_MESSAGE_LIMIT=50
# Set to "false" to disable the ramp and use a flat DAILY_MESSAGE_LIMIT cap.
WARMUP_ENABLED=true

# Where the WhatsApp login session + warm-up/dedupe state are stored. MUST be a
# persisted Docker volume (see docker-compose.yml) so a redeploy never re-scans.
SESSION_DIR=./session
# Append-only send log: ISO-timestamp <tab> phone <tab> status <tab> error
LOG_FILE=./logs/messages.log

# pino log level (warn|info|debug)
LOG_LEVEL=warn
