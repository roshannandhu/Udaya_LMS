# NOTE: .env / .env.local are intentionally COMMITTED so collaborators can
# `git clone` and run immediately against the shared Supabase project. See
# SETUP.md. (Repo MUST stay private — these files contain the Supabase
# service_role key which grants full DB access.)

# teacher_settings.json holds a private AI (Gemini) API key — NOT committed
# (GitHub push protection blocks it). Each user adds their own AI key in the
# teacher Settings page if they want the AI mentorship feature.
teacher_settings.json

# ai_insights_cache.json is the server-side AI mentor response cache —
# regenerated data, never committed.
ai_insights_cache.json

# whatsapp_config.json holds the WhatsApp provider (WANotifier) API key + sender
# number — server-only secret, NOT committed. Each teacher adds their own key in
# the WhatsApp → Settings tab.
whatsapp_config.json
backend/whatsapp_config.json

# Screenshots & Images
screenshots/
*.png
*.jpg
*.jpeg

# ...but the app's own brand/icon assets in public/ MUST ship to Vercel
!frontend/public/*.png
!frontend/public/*.jpg
!frontend/public/*.jpeg

# Test tokens & scripts
.test_token
verify_run.mjs
verify_test.js
verify_test.mjs
subjects_page_redesign.html
*.timestamp-*.mjs

.vercel

# Android signing & Firebase — NEVER commit.
# Losing the keystore (or committing it) means you can never update the app again.
*.jks
*.keystore
google-services.json
android/app/build/
android/.gradle/
