# Reverse proxy + HTTPS for the FastAPI backend. See LAUNCH_PLAN.md §4 / §14.
#
# Uses a Cloudflare Origin Certificate (saved on the box as ./cf-origin/cert.pem + key.pem).
# Cloudflare proxies api.udaya-learn.com to this box on :443 with SSL mode "Full (strict)".
api.udaya-learn.com {
    tls /etc/caddy/cf-origin/cert.pem /etc/caddy/cf-origin/key.pem
    reverse_proxy api:8001
}
